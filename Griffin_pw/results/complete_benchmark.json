{
  "_paper": {
    "title": "Hybrid Recurrence-Attention Architecture: Complete Benchmark Results",
    "proposed_model": "Griffin (hybrid: recurrence + local attention, window=64)",
    "baselines": {
      "Hawk": "Pure recurrence. Unbounded sequential memory, no attention.",
      "Local Attention": "Local window attention, window=64. Structurally blind beyond 64 tokens."
    },
    "paper_goal": "Show Griffin achieves the best of both worlds: long-range memory from recurrence AND local precision from attention.",
    "key_threshold": "64 tokens = local attention window. Recall gaps > 64 are structurally inaccessible to Local Attention.",
    "claims": {
      "C1": "Hawk outperforms Local Attention on recurrence-dependent tasks. Griffin matches or beats Hawk (hybrid does not regress).",
      "C2": "Local Attention outperforms Hawk on local-precision tasks. Griffin matches or beats Local Attention (hybrid captures both)."
    }
  },
